{
  "name": "iso-42001-ai-mcp",
  "description": "AI-powered iso 42001 ai MCP server for agents. Supports audit management system, assess ai risk, generate policy template. By MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "audit_management_system",
      "description": "Audit an AI management system against ISO/IEC 42001 clauses 4-10.",
      "parameters": {
        "type": "object",
        "properties": {
          "organization_description": {
            "type": "string"
          },
          "ai_systems_description": {
            "type": "string"
          },
          "existing_certifications": {
            "type": "string"
          },
          "caller": {
            "type": "string"
          },
          "tier": {
            "type": "string"
          }
        },
        "required": [
          "organization_description"
        ]
      }
    },
    {
      "name": "assess_ai_risk",
      "description": "Perform ISO 42001 Annex B risk assessment for AI systems.",
      "parameters": {
        "type": "object",
        "properties": {
          "system_description": {
            "type": "string"
          },
          "system_name": {
            "type": "string"
          },
          "risk_criteria": {
            "type": "string"
          },
          "caller": {
            "type": "string"
          },
          "tier": {
            "type": "string"
          }
        },
        "required": [
          "system_description"
        ]
      }
    },
    {
      "name": "generate_policy_template",
      "description": "Generate AI policy documents per ISO 42001 requirements.",
      "parameters": {
        "type": "object",
        "properties": {
          "organization_name": {
            "type": "string"
          },
          "ai_scope": {
            "type": "string"
          },
          "policy_type": {
            "type": "string"
          },
          "caller": {
            "type": "string"
          },
          "tier": {
            "type": "string"
          }
        },
        "required": [
          "organization_name"
        ]
      }
    },
    {
      "name": "check_annex_controls",
      "description": "Evaluate AI system against ISO 42001 Annex A controls.",
      "parameters": {
        "type": "object",
        "properties": {
          "system_description": {
            "type": "string"
          },
          "system_name": {
            "type": "string"
          },
          "implemented_controls": {
            "type": "string"
          },
          "caller": {
            "type": "string"
          },
          "tier": {
            "type": "string"
          }
        },
        "required": [
          "system_description"
        ]
      }
    },
    {
      "name": "crosswalk_to_eu_ai_act",
      "description": "Map ISO/IEC 42001 clauses and Annex A controls to EU AI Act articles.",
      "parameters": {
        "type": "object",
        "properties": {
          "iso_clauses": {
            "type": "string"
          },
          "focus_area": {
            "type": "string"
          },
          "caller": {
            "type": "string"
          },
          "tier": {
            "type": "string"
          }
        },
        "required": []
      }
    },
    {
      "name": "create_certification_checklist",
      "description": "Generate ISO 42001 certification readiness checklist with pass/fail.",
      "parameters": {
        "type": "object",
        "properties": {
          "organization_name": {
            "type": "string"
          },
          "current_status": {
            "type": "string"
          },
          "target_date": {
            "type": "string"
          },
          "caller": {
            "type": "string"
          },
          "tier": {
            "type": "string"
          }
        },
        "required": []
      }
    }
  ]
}